# =======================================
# Firebase Configuration - DO NOT COMMIT .env
# Replace with your actual values in .env file
# =======================================
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here
FIREBASE_IOS_BUNDLE_ID=com.snapbudget.snapbudgetOcr

# =======================================
# Android Configuration - DO NOT COMMIT .env
# Replace with your actual paths in .env file
# =======================================
ANDROID_SDK_PATH=C:\\Users\\YOUR_USERNAME\\AppData\\Local\\Android\\sdk
FLUTTER_SDK_PATH=C:\\path\\to\\flutter
FLUTTER_BUILD_MODE=debug
FLUTTER_VERSION_NAME=1.0.0
FLUTTER_VERSION_CODE=1

# =======================================
# Backend API Configuration
# =======================================
BACKEND_API_URL=http://localhost:8000
GEMINI_API_KEY=your_gemini_api_key_here

# =======================================
# App Configuration
# =======================================
APP_ENV=development
APP_NAME=SmartBudgetOCR
